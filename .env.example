# Database — use 'db' as the host when running via Docker Compose,
# use 'localhost' when running the backend directly on your machine.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/degreebaba_ai

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:2323,http://localhost:8080,https://degreebaba.com,https://www.degreebaba.com

# JSON map of site keys to allowed domains
# Format: {"site_key":["domain1","domain2"]}
ALLOWED_SITE_KEYS={"degreebaba_dev":["localhost","127.0.0.1"],"degreebaba_prod":["degreebaba.com","www.degreebaba.com"]}

# Optional: forward lead captures to your CRM webhook
CRM_WEBHOOK_URL=

# Admin panel auth token — change this before deploying!
ADMIN_AUTH_TOKEN=change-me

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
DAILY_MESSAGE_CAP_PER_SITE=2000

# Must match POSTGRES_PASSWORD in docker-compose.yml
POSTGRES_PASSWORD=postgres
