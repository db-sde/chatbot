# Database — use 'db' as the host when running via Docker Compose,
# use 'localhost' when running the backend directly on your machine.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/degreebaba_ai

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: override default LLM model names
GROQ_MODEL_NAME=llama-3.3-70b-versatile
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Optional: Gemini API key (used for embeddings and fallback chat)
GEMINI_API_KEY=
# JSON map of site keys to allowed domains — this is now the ONLY place CORS
# origins and Origin/Referer validation are configured. CORS allow_origins is
# derived from this at startup (see settings.py: allowed_origins property),
# so there is no separate ALLOWED_ORIGINS variable to keep in sync anymore.
# Format: {"site_key":["domain1","domain2"]}
ALLOWED_SITE_KEYS={"degreebaba_dev":["localhost","127.0.0.1"],"degreebaba_prod":["degreebaba.com","www.degreebaba.com"]}

# Comma-separated list of IPs allowed to set X-Forwarded-For (your reverse
# proxy — Nginx/Caddy/Cloudflare Tunnel). Required in production so SlowAPI's
# rate limiter sees the real visitor IP instead of the proxy's IP for every
# request. Defaults to 127.0.0.1 (proxy on the same host). If the proxy runs
# on a different host/container, set its IP here instead.
TRUSTED_PROXIES=127.0.0.1

# Optional: forward lead captures to your CRM webhook
CRM_WEBHOOK_URL=

# Admin panel auth token — change this before deploying!
ADMIN_AUTH_TOKEN=change-me

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
DAILY_MESSAGE_CAP_PER_SITE=2000

# Must match POSTGRES_PASSWORD in docker-compose.yml
POSTGRES_PASSWORD=postgres
